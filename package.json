{
  "name": "pi-mlx",
  "version": "0.1",
  "description": "Local MLX model launcher extension for Pi",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "dev": "bunx tsc -w -p tsconfig.json",
    "prepack": "bun run build"
  },
  "keywords": [
    "pi-package",
    "pi",
    "mlx",
    "llm",
    "extension"
  ],
  "author": "kenbanks-peng",
  "license": "MIT",
  "repository": {
    "type": "git",
     "url": "git+https://github.com/kenbanks-peng/pi-mlx-models.git"
  },
  "bugs": {
     "url": "https://github.com/kenbanks-peng/pi-mlx-models/issues"
  },
   "homepage": "https://github.com/kenbanks-peng/pi-mlx-models#readme",
  "pi": {
    "extensions": [
      "dist/index.js"
    ],
     "image": "https://raw.githubusercontent.com/kenbanks-peng/pi-mlx-models/main/assets/preset-selector.png"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
